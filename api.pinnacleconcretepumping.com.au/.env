# Pinnacle Concrete Pumping API config (cPanel side) — NOT committed to git.
# Upload this file alongside form.php / form-quote.php / env.php into the
# docroot of api.pinnacleconcretepumping.com.au.

# ----- reCAPTCHA v3 -----
RECAPTCHA_SECRET=6LfKPfcsAAAAABIXUz8ybXhf5ovcNJhtHwjNSBsa
RECAPTCHA_MIN_SCORE=0.5

# ----- Mail addressing -----
# On cPanel, mail() pipes into the local Exim queue, so the From address
# just needs to be a valid local mailbox on this host's domain.
RECIPIENT_EMAIL=info@pinnacleconcretepumping.com.au
SENDER_EMAIL=no-reply@pinnacleconcretepumping.com.au
SENDER_NAME="Pinnacle Concrete Pumping Website"

# Optional CC / BCC — comma-separated for multiple addresses. Leave blank to disable.
MAIL_CC=jasmine.jaafar@aiims.group
MAIL_BCC=kynan.albassit@aiims.group,robert.devera@aiims.group

# ----- CORS -----
# Comma-separated list of allowed Origin headers, or * to allow any.
# Tighten this once the production domain is live, e.g.:
#   ALLOWED_ORIGINS=https://pinnacleconcretepumping.com.au,https://www.pinnacleconcretepumping.com.au
ALLOWED_ORIGINS=*
