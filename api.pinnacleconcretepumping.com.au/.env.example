# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real secrets.

# ----- reCAPTCHA v3 -----
RECAPTCHA_SECRET=YOUR_RECAPTCHA_SECRET_KEY_HERE
RECAPTCHA_MIN_SCORE=0.5

# ----- Mail addressing -----
RECIPIENT_EMAIL=info@pinnacleconcretepumping.com.au
SENDER_EMAIL=no-reply@pinnacleconcretepumping.com.au
SENDER_NAME="Pinnacle Concrete Pumping Website"

# Optional CC / BCC — comma-separated. Leave blank to disable.
# Example: MAIL_CC=sales@pinnacleconcretepumping.com.au,manager@pinnacleconcretepumping.com.au
MAIL_CC=
MAIL_BCC=

# ----- CORS -----
# Comma-separated list of allowed Origin headers, or * for any.
ALLOWED_ORIGINS=*
